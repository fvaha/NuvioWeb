# Copy to .env and fill in. The Go server reads .env from cwd unless vars are already set.
# Optional: TMOVIE_DOTENV=/path/to/.env

# HTTP bind port
PORT=8080

# Required for search and catalog (https://www.themoviedb.org/settings/api)
TMDB_API_KEY=

# Optional: IMDb rating / Metascore in catalog (https://www.omdbapi.com/apikey.aspx)
OMDB_API_KEY=

# OpenSubtitles.com REST (search + download subtitles) — Api-Key from profile + account login
OPENSUBTITLES_API_KEY=
OPENSUBTITLES_USERNAME=
OPENSUBTITLES_PASSWORD=

# SQLite database file (relative to cwd or absolute)
SQLITE_PATH=data/tmovie.db

# Where downloaded .srt files are stored and served under /files/
PUBLIC_DIR=data/public

# CORS: * or comma-separated origins (e.g. http://192.168.1.20,http://localhost:8080)
CORS_ORIGINS=*

# Optional: your own video files for Samsung AVPlay (no VidSrc extractor).
# JSON maps TMDB ids -> path relative to LOCAL_LIBRARY_ROOT (see data/local_media_map.example.json).
LOCAL_LIBRARY_ROOT=
LOCAL_MEDIA_MAP=
# Optional: full origin for catalog URLs if reverse proxy hides Host (e.g. http://YOUR_SERVER_IP:8080)
PUBLIC_BASE_URL=
# Optional: your tuned ffmpeg binary (reserved for future server-side transcode hooks)
FFMPEG_BIN=

# Optional: static dashboard folder (default ./web/dashboard)
TMOVIE_DASHBOARD_DIR=

# Optional: only used by /api/v1/status hint and run-with-prevodi-keys.sh
PREVODI_BACKEND_PY=

# Self-hosted torrent resolver (debrid replacement). Set to enable.
TORRENT_DIR=data/torrents
# Bearer token gating control routes; generated by HELPERS/install.sh
TMOVIE_API_TOKEN=

# SubDL subtitles addon (imdb-id based; works for torrents). Free key: subdl.com -> panel -> API
SUBDL_API_KEY=
# Languages queried from SubDL (default EN). Balkan+EN example below.
SUBDL_LANGUAGES=EN,HR,SR,BS,SL,MK
